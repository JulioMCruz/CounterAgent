# Copy to a local shell/env file outside git or export these values manually.
# These must point to separate running AXL nodes for the real P2P test.

# A0 local node API. This is where A0 sends outbound messages.
AXL_A0_URL=https://orchestrator.counteragents.cc/axl

# A1/A2/A3/A4 node APIs. These are polled for received messages and MCP routing checks.
AXL_A1_URL=https://monitor.counteragents.cc/axl
AXL_A2_URL=https://decision.counteragents.cc/axl
AXL_A3_URL=https://execution.counteragents.cc/axl
AXL_A4_URL=https://reporting.counteragents.cc/axl

# Destination peer IDs as reported by each receiving node topology.
AXL_PEER_A1="<A1_PEER_ID>"
AXL_PEER_A2="<A2_PEER_ID>"
AXL_PEER_A3="<A3_PEER_ID>"
AXL_PEER_A4="<A4_PEER_ID>"

# Public agent endpoints are HTTPS.
REQUIRE_HTTPS_AXL=true

# Set to true only when intentionally testing multiple local node processes.
ALLOW_LOCAL_AXL=false

# CounterAgent local ports used by the workflow test.
A0_PORT=8787
A1_PORT=8788
A2_PORT=8790
A3_PORT=8791
A4_PORT=8789

# Real AXL MCP service names.
GENSYN_AXL_SERVICE_A1=counteragent-monitor
GENSYN_AXL_SERVICE_A2=counteragent-decision
GENSYN_AXL_SERVICE_A3=counteragent-execution
GENSYN_AXL_SERVICE_A4=counteragent-reporting

# Existing CounterAgent DNS inventory.
APP_URL=https://counteragents.cc
A0_DOMAIN=https://orchestrator.counteragents.cc
A1_DOMAIN=https://monitor.counteragents.cc
A2_DOMAIN=https://decision.counteragents.cc
A3_DOMAIN=https://execution.counteragents.cc
A4_DOMAIN=https://reporting.counteragents.cc
A0_AXL_URL=https://orchestrator.counteragents.cc/axl
A1_AXL_URL=https://monitor.counteragents.cc/axl
A2_AXL_URL=https://decision.counteragents.cc/axl
A3_AXL_URL=https://execution.counteragents.cc/axl
A4_AXL_URL=https://reporting.counteragents.cc/axl
