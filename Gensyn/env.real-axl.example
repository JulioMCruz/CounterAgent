# Copy to a local shell/env file outside git or export these values manually.
# These must point to separate running AXL nodes for the real P2P test.

# A0 local node API. This is where A0 sends outbound messages.
AXL_A0_URL=http://orchestrator.counteragents.cc/axl

# A2 and A3 node APIs. These are polled for received messages.
AXL_A2_URL=http://decision.counteragents.cc/axl
AXL_A3_URL=http://execution.counteragents.cc/axl

# Destination peer IDs as reported by each receiving node topology.
AXL_PEER_A2="<A2_PEER_ID>"
AXL_PEER_A3="<A3_PEER_ID>"

# Set to true when TLS is enabled on the public agent endpoints.
REQUIRE_HTTPS_AXL=false

# Set to true only when intentionally testing multiple local node processes.
ALLOW_LOCAL_AXL=false

# CounterAgent local ports used by the workflow test.
A0_PORT=8787
A2_PORT=8790
A3_PORT=8791

# Optional: real AXL MCP service names if your AXL bridge exposes MCP over peer routing.
GENSYN_AXL_SERVICE_A2=counteragent-decision
GENSYN_AXL_SERVICE_A3=counteragent-execution

# Existing CounterAgent DNS inventory
APP_URL=http://counteragents.cc
A0_DOMAIN=http://orchestrator.counteragents.cc
A1_DOMAIN=http://monitor.counteragents.cc
A2_DOMAIN=http://decision.counteragents.cc
A3_DOMAIN=http://execution.counteragents.cc
A4_DOMAIN=http://reporting.counteragents.cc
A0_AXL_URL=http://orchestrator.counteragents.cc/axl
A1_AXL_URL=http://monitor.counteragents.cc/axl
A2_AXL_URL=http://decision.counteragents.cc/axl
A3_AXL_URL=http://execution.counteragents.cc/axl
A4_AXL_URL=http://reporting.counteragents.cc/axl
