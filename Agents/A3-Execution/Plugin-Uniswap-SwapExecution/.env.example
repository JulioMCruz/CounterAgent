PORT=8791
CORS_ORIGIN=https://counteragent.netlify.app
EXECUTION_MODE=dry-run
UNISWAP_QUOTE_MODE=api-first
CHAIN_ID=84532
BASE_RPC_URL=https://sepolia.base.org
UNISWAP_API_URL=https://trade-api.gateway.uniswap.org/v1
UNISWAP_API_KEY=<UNISWAP_API_KEY>
UNISWAP_RETRY_COUNT=2
UNISWAP_TIMEOUT_MS=10000

# Optional per-chain token overrides for real testnet deployments.
# If unset, the plugin uses canonical Base mainnet stablecoin addresses as sponsor-visible defaults.
USDC_TOKEN_ADDRESS_84532=<USDC_ON_BASE_SEPOLIA>
EURC_TOKEN_ADDRESS_84532=<EURC_ON_BASE_SEPOLIA>
USDT_TOKEN_ADDRESS_84532=<USDT_ON_BASE_SEPOLIA>

# Optional fallback tuning. Rates still come from user/oracle inputs (dryRunRate/baselineRate), not hardcoded pairs.
FALLBACK_FEE_BPS=5
FALLBACK_PRICE_IMPACT_BPS=0

KEEPERHUB_API_URL=<KEEPERHUB_API_URL>
KEEPERHUB_API_KEY=<KEEPERHUB_API_KEY>
EXECUTOR_PRIVATE_KEY=<SERVER_SIDE_ONLY>
