PORT=8791
CORS_ORIGIN=https://counteragent.netlify.app
# dry-run | vault-dry-run | vault-live
EXECUTION_MODE=dry-run
UNISWAP_QUOTE_MODE=api-first
CHAIN_ID=84532
BASE_RPC_URL=https://sepolia.base.org
CELO_RPC_URL=https://forno.celo.org
CELO_ALFAJORES_RPC_URL=https://alfajores-forno.celo-testnet.org
CELO_SEPOLIA_RPC_URL=https://forno.celo-sepolia.celo-testnet.org
UNISWAP_API_URL=https://trade-api.gateway.uniswap.org/v1
UNISWAP_API_KEY=<UNISWAP_API_KEY>
UNISWAP_RETRY_COUNT=2
UNISWAP_TIMEOUT_MS=10000

# Circle Base Sepolia testnet stablecoins used by the dashboard demo.
# If unset, the plugin uses canonical Base mainnet stablecoin addresses as sponsor-visible defaults.
USDC_TOKEN_ADDRESS_84532=0x036CbD53842c5426634e7929541eC2318f3dCF7e
EURC_TOKEN_ADDRESS_84532=0x808456652fdb597867f38412077A9182bf77359F
USDT_TOKEN_ADDRESS_84532=<USDT_ON_BASE_SEPOLIA>

# Celo mainnet defaults are built into A3, but may be overridden per deployment.
CELO_TOKEN_ADDRESS_42220=0x471EcE3750Da237f93B8E339c536989b8978a438
USDC_TOKEN_ADDRESS_42220=0xcebA9300f2b948710d2653dD7B07f33A8B32118C
USDT_TOKEN_ADDRESS_42220=0x48065fbBE25f71C9282ddf5e1cD6D6A887483D5e
CUSD_TOKEN_ADDRESS_42220=0x765DE816845861e75A25fCA122bb6898B8B1282a
CEUR_TOKEN_ADDRESS_42220=0xD8763CBa276a3738E6DE85b4b3bF5FDed6D6cA73

# Optional direct Uniswap v4 pool fallback for Base Sepolia and Celo demos.
# Used when the Trading API is reachable but returns no route for testnet/local liquidity.
V4_QUOTER_84532=0x4a6513c898fe1b2d0e78d3b0e0a4a151589b1cba
V4_QUOTER_42220=0x28566da1093609182dff2cb2a91cfd72e61d66cd
UNIVERSAL_ROUTER_ADDRESS_42220=0xcb695bc5D3Aa22cAD1E6DF07801b061a05A0233A
V4_POOL_FEE=500
V4_TICK_SPACING=10

# Last-resort fallback tuning. Rates still come from user/oracle inputs (dryRunRate/baselineRate), not hardcoded pairs.
FALLBACK_FEE_BPS=5
FALLBACK_PRICE_IMPACT_BPS=0

KEEPERHUB_API_URL=<KEEPERHUB_API_URL>
KEEPERHUB_API_KEY=<KEEPERHUB_API_KEY>
# Vault autopilot execution. Base Sepolia factory is public deployment metadata.
TREASURY_VAULT_FACTORY_ADDRESS=0x6FBbFb4F41b2366B10b93bae5D1a1A4aC3c734BA
UNIVERSAL_ROUTER_ADDRESS_84532=<UNIVERSAL_ROUTER_BASE_SEPOLIA>
EXECUTOR_PRIVATE_KEY=<SERVER_SIDE_ONLY>
