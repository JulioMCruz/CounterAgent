PORT=8791
CORS_ORIGIN=https://counteragent.netlify.app
EXECUTION_MODE=dry-run
UNISWAP_QUOTE_MODE=api-first
CHAIN_ID=84532
BASE_RPC_URL=https://sepolia.base.org
UNISWAP_API_URL=https://trade-api.gateway.uniswap.org/v1
UNISWAP_API_KEY=<UNISWAP_API_KEY>
UNISWAP_RETRY_COUNT=2
UNISWAP_TIMEOUT_MS=10000

# Circle Base Sepolia testnet stablecoins used by the dashboard demo.
# If unset, the plugin uses canonical Base mainnet stablecoin addresses as sponsor-visible defaults.
USDC_TOKEN_ADDRESS_84532=0x036CbD53842c5426634e7929541eC2318f3dCF7e
EURC_TOKEN_ADDRESS_84532=0x808456652fdb597867f38412077A9182bf77359F
USDT_TOKEN_ADDRESS_84532=<USDT_ON_BASE_SEPOLIA>

# Optional direct Uniswap v4 pool fallback for Base Sepolia demos.
# Used when the Trading API is reachable but returns no route for testnet USDC/EURC.
V4_QUOTER_84532=0x4a6513c898fe1b2d0e78d3b0e0a4a151589b1cba
V4_POOL_FEE=500
V4_TICK_SPACING=10

# Last-resort fallback tuning. Rates still come from user/oracle inputs (dryRunRate/baselineRate), not hardcoded pairs.
FALLBACK_FEE_BPS=5
FALLBACK_PRICE_IMPACT_BPS=0

KEEPERHUB_API_URL=<KEEPERHUB_API_URL>
KEEPERHUB_API_KEY=<KEEPERHUB_API_KEY>
EXECUTOR_PRIVATE_KEY=<SERVER_SIDE_ONLY>
