(counteragent_headers) {
  encode gzip zstd
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "no-referrer-when-downgrade"
  }
}

# counteragents.cc is served by the Netlify app. Agent subdomains terminate HTTPS here.

orchestrator.counteragents.cc {
  import counteragent_headers
  @axl_status path /axl/status
  handle @axl_status {
    reverse_proxy orchestrator-plugin:8787
  }

  @axl path /axl/*
  handle @axl {
    uri strip_prefix /axl
    reverse_proxy axl-a0-transport:8890
  }

  @orchestrator_api path /session/* /onboarding/* /workflow/* /vault/* /ens/* /dashboard/* /healthz
  handle @orchestrator_api {
    reverse_proxy orchestrator-plugin:8787
  }

  handle {
    reverse_proxy a0-orchestrator:3000
  }
}

monitor.counteragents.cc {
  import counteragent_headers
  @axl path /axl/*
  handle @axl {
    uri strip_prefix /axl
    reverse_proxy axl-a1-transport:8891
  }

  reverse_proxy monitor-plugin:8788
}

decision.counteragents.cc {
  import counteragent_headers
  @axl path /axl/*
  handle @axl {
    uri strip_prefix /axl
    reverse_proxy axl-a2-transport:8892
  }

  reverse_proxy decision-scoring-plugin:8790
}

execution.counteragents.cc {
  import counteragent_headers
  @axl path /axl/*
  handle @axl {
    uri strip_prefix /axl
    reverse_proxy axl-a3-transport:8893
  }

  reverse_proxy uniswap-swap-plugin:8791
}

reporting.counteragents.cc {
  import counteragent_headers
  @axl path /axl/*
  handle @axl {
    uri strip_prefix /axl
    reverse_proxy axl-a4-transport:8894
  }

  reverse_proxy reporting-plugin:8789
}
