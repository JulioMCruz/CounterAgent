(counteragent_headers) {
  encode gzip zstd
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "no-referrer-when-downgrade"
  }
}

counteragent.perkos.xyz {
  import counteragent_headers
  @axl_status path /axl/status
  handle @axl_status {
    reverse_proxy orchestrator-plugin:8787
  }

  @axl path /axl/*
  handle @axl {
    uri strip_prefix /axl
    reverse_proxy axl-a0-transport:8890
  }

  @orchestrator_api path /session/* /onboarding/* /workflow/* /vault/* /ens/* /dashboard/*
  handle @orchestrator_api {
    reverse_proxy orchestrator-plugin:8787
  }

  handle {
    reverse_proxy a0-orchestrator:18789
  }
}

