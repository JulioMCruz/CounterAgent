  import counteragent_headers
  @orchestrator_api path /session/* /onboarding/* /workflow/* /vault/* /ens/* /dashboard/*
  handle @orchestrator_api {
    reverse_proxy orchestrator-plugin:8787
  }

  handle {
    reverse_proxy a0-orchestrator:18789
  }
}

