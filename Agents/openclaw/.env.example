OPENAI_API_KEY=<OPENAI_API_KEY>
ANTHROPIC_API_KEY=

COUNTERAGENT_DOMAIN=counteragents.cc
A0_DOMAIN=orchestrator.counteragents.cc
A1_DOMAIN=monitor.counteragents.cc
A2_DOMAIN=decision.counteragents.cc
A3_DOMAIN=execution.counteragents.cc
A4_DOMAIN=reporting.counteragents.cc

AXL_MODE=local
AXL_REQUIRE_REAL_NODE=false
AXL_PEER_A0=counteragent-a0
AXL_PEER_A1=counteragent-a1
AXL_PEER_A2=counteragent-a2
AXL_PEER_A3=counteragent-a3
AXL_PEER_A4=counteragent-a4
AXL_A0_NODE_URL=
AXL_A1_NODE_URL=
AXL_A2_NODE_URL=
AXL_A3_NODE_URL=
AXL_A4_NODE_URL=

OPENCLAW_TOKEN_A0=<GENERATE_WITH_OPENSSL_RAND_HEX_32>
OPENCLAW_TOKEN_A1=<GENERATE_WITH_OPENSSL_RAND_HEX_32>
OPENCLAW_TOKEN_A2=<GENERATE_WITH_OPENSSL_RAND_HEX_32>
OPENCLAW_TOKEN_A3=<GENERATE_WITH_OPENSSL_RAND_HEX_32>
OPENCLAW_TOKEN_A4=<GENERATE_WITH_OPENSSL_RAND_HEX_32>
PINATA_JWT=<PINATA_SERVER_SIDE_JWT>
PINATA_GATEWAY_URL=https://gateway.pinata.cloud/ipfs
IPFS_UPLOAD_MAX_BYTES=10000000

TELEGRAM_BOT_TOKEN=<SERVER_SIDE_ONLY>
TELEGRAM_ALERTS_ENABLED=true
TELEGRAM_TIMEOUT_MS=8000
